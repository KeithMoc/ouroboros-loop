# Local-only doc convention — anything intended to stay on the maintainer's
# machine (private notes, strategy drafts, personal handoffs) goes in one of
# these paths. The privacy-leak-guard pre-commit hook (scripts/check-privacy-leaks.sh)
# catches accidental leaks of /home/<user>/ paths, personal emails, etc., but the
# first line of defense is keeping local content here so it never reaches staging.
docs/local/
notes/local/
**/*.local.md
**/*.private.md


# Local archive for removed/held docs and assets
archive/

# Git worktrees (local development isolation)
.worktrees/

# Generated doc reports (regenerable via scripts/)
docs/link-index.md
docs/link-index.json
docs/cross-document-link-index.md
docs/section-content-index.md
docs/section-content-index.json
docs/semantic-link-rot-report.md
docs/doc-issues-register.md
docs/doc-volatility-report.md
docs/doc-volatility-report.json
docs/doc-maintenance-ranking.yaml
docs/findings-file-inventory.md
docs/claim-inventory.md
docs/config-inventory.md
docs/runtime-capability-crosscheck.md
docs/authority-model-migration-report.json
docs/claim-status-derivation-audit.yaml
docs/code-surface-inventory.yaml
docs/code-surface-lookup.yaml
docs/cli-inventory.yaml

# Runtime evaluation artifact written by the evaluation MCP handler
# (see src/ouroboros/mcp/tools/evaluation_handlers.py)
.ouroboros_eval_artifact.md

# End-of-run postmortem chain artifacts written by SerialCompoundingExecutor
# (see src/ouroboros/orchestrator/serial_executor.py write_chain_artifact)
# These are per-session inspection files, not permanent project documentation.
docs/brainstorm/chain-*.md

# Parking-lot audit per-run worktrees (created by scripts/audit/run_parking_lot_bench.sh).
# The harness uses `git worktree add` for isolation; these are ephemeral checkouts.
.audit-worktrees/

# Per-run audit artifacts. The dir + REPORT.md + scores.json are tracked, but the heavy
# raw outputs / event stores per run aren't worth committing.
examples/parking-lot-audit/runs/*/output/
examples/parking-lot-audit/runs/*/events.sqlite
examples/parking-lot-audit/runs/*/session.log
examples/parking-lot-audit/runs/*/commits.log
examples/parking-lot-audit/runs/*/metrics.json
examples/parking-lot-audit/bench-driver.log

# Parking-lot audit v2 — same shape as v1 (per-run heavy data ignored, REPORT/scores tracked)
examples/parking-lot-audit-v2/runs/*/output/
examples/parking-lot-audit-v2/runs/*/events.sqlite
examples/parking-lot-audit-v2/runs/*/session.log
examples/parking-lot-audit-v2/runs/*/commits.log
examples/parking-lot-audit-v2/runs/*/metrics.json
examples/parking-lot-audit-v2/bench-driver.log
